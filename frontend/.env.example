VITE_API_URL=http://localhost:8794
VITE_POD_PROVIDER_BASE_URL=http://localhost:3000

# Klipy GIF API key for GIF search/trending/recent integration.
# Required to enable GIF picker data loading.
VITE_KLIPY_APP_KEY=

# Maximum age (ms) of a trusted browser session before forcing sign-in again.
VITE_SESSION_MAX_AGE_MS=28800000

# While webhook delivery is active, defer pod credential reauth prompts for this
# bounded duration (ms) when provider reports an upgrade-needed state.
VITE_POD_REAUTH_DEFER_MS=14400000

# Operator-only diagnostics panel in notifications view.
# Keep false in user-facing environments.
VITE_SHOW_OPERATOR_DIAGNOSTICS=false