      "definition": "SELECT\n    posts.*,\n    users.name as author_name,\n    users.web_id as author_web_id,\n    users.provider_endpoint as author_provider_endpoint\n  FROM posts\n  INNER JOIN users on posts.author_id = users.id\n  WHERE posts.is_public = true",
